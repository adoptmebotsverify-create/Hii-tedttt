local AntiLag = {
    MaxPetsAtOnce = 40,           -- Maximum pets visible at once
    PetLifetime = 6,               -- Seconds before pet auto-destroys
    SpawnDelay = 0.05,              -- Delay between spawns
    BatchSize = 20,                 -- Spawn in batches of 20
    BatchDelay = 0.2,               -- Delay between batches
    EnableTrails = true,            
    EnableLights = true,            
    EnableOutlines = true,          -- Enable pet outlines
    LowQualityMode = false,         
    LastGarbageCollect = 0,
    GarbageCollectInterval = 5,     -- Clean up every 5 seconds
    ContinuousMode = false,         -- Whether continuous rain is active
}

-- Performance monitoring
local FPSMonitor = {
    frames = 0,
    lastTime = tick(),
    currentFPS = 60
}

local function updateFPS()
    FPSMonitor.frames = FPSMonitor.frames + 1
    local currentTime = tick()
    if currentTime - FPSMonitor.lastTime >= 1 then
        FPSMonitor.currentFPS = FPSMonitor.frames
        FPSMonitor.frames = 0
        FPSMonitor.lastTime = currentTime
        
        -- Auto-adjust quality based on FPS
        if FPSMonitor.currentFPS < 25 then
            AntiLag.LowQualityMode = true
            AntiLag.EnableTrails = false
            AntiLag.EnableLights = false
            AntiLag.EnableOutlines = true -- Keep outlines even in low quality
            AntiLag.MaxPetsAtOnce = 25
        elseif FPSMonitor.currentFPS < 40 then
            AntiLag.LowQualityMode = true
            AntiLag.EnableTrails = true
            AntiLag.EnableLights = false
            AntiLag.EnableOutlines = true
            AntiLag.MaxPetsAtOnce = 35
        else
            AntiLag.LowQualityMode = false
            AntiLag.EnableTrails = true
            AntiLag.EnableLights = true
            AntiLag.EnableOutlines = true
            AntiLag.MaxPetsAtOnce = 40
        end
    end
end

-- Garbage collector to clean up old pets
local function garbageCollect()
    local currentTime = tick()
    if currentTime - AntiLag.LastGarbageCollect < AntiLag.GarbageCollectInterval then
        return
    end
    AntiLag.LastGarbageCollect = currentTime
    
    -- Count active pets
    local petCount = 0
    for _, pet in pairs(activePets) do
        if pet and pet.Parent then
            petCount = petCount + 1
        end
    end
    
    -- If too many pets, remove oldest ones
    if petCount > AntiLag.MaxPetsAtOnce then
        local toRemove = petCount - AntiLag.MaxPetsAtOnce
        local removed = 0
        
        -- Sort pets by creation time
        local petList = {}
        for id, pet in pairs(activePets) do
            if pet and pet.Parent then
                local creationTime = pet:GetAttribute("CreationTime") or 0
                table.insert(petList, {id = id, pet = pet, time = creationTime})
            end
        end
        
        table.sort(petList, function(a, b) return a.time < b.time end)
        
        -- Remove oldest pets
        for i = 1, math.min(toRemove, #petList) do
            local petData = petList[i]
            if petData.pet and petData.pet.Parent then
                petData.pet:Destroy()
                activePets[petData.id] = nil
                removed = removed + 1
            end
        end
    end
    
    -- Force Lua garbage collection
    collectgarbage()
end

