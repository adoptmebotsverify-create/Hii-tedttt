local function GetAnimationType(petModel)
    local animType = selectedAnim
    if animType == "Random" then
        animType = PetAnimations[math.random(1, #PetAnimations)]
    end
    
    local animData = AnimationMap[animType] or AnimationMap.Spin
    return animType, animData
end

local function ApplyAnimation(petModel, animType, animData)
    if not petModel or not petModel.PrimaryPart then return end
    
    local primaryPart = petModel.PrimaryPart
    local speed = animData.speed * (_G.AnimSpeed or 1)
    local baseCF = primaryPart.CFrame
    
    if animData.type == "spin" then
        -- Continuous spinning
        local spinConnection
        spinConnection = RunService.Heartbeat:Connect(function(dt)
            if petModel and petModel.PrimaryPart then
                petModel:SetPrimaryPartCFrame(petModel.PrimaryPart.CFrame * CFrame.Angles(0, dt * speed * 5, 0))
            else
                spinConnection:Disconnect()
            end
        end)
        return spinConnection
        
    elseif animData.type == "flop" then
        -- Side to side flopping
        local time = 0
        local flopConnection
        flopConnection = RunService.Heartbeat:Connect(function(dt)
            if petModel and petModel.PrimaryPart then
                time = time + dt
                local angle = math.sin(time * speed * 3) * 0.5
                petModel:SetPrimaryPartCFrame(petModel.PrimaryPart.CFrame * CFrame.Angles(angle, 0, angle * 0.5))
            else
                flopConnection:Disconnect()
            end
        end)
        return flopConnection
        
    elseif animData.type == "twirl" then
        -- Graceful twirling
        local time = 0
        local twirlConnection
        twirlConnection = RunService.Heartbeat:Connect(function(dt)
            if petModel and petModel.PrimaryPart then
                time = time + dt
                local yAngle = dt * speed * 4
                local xAngle = math.sin(time * 2) * 0.2
                petModel:SetPrimaryPartCFrame(petModel.PrimaryPart.CFrame * CFrame.Angles(xAngle, yAngle, 0))
            else
                twirlConnection:Disconnect()
            end
        end)
        return twirlConnection
        
    elseif animData.type == "bounce" then
        -- Bouncing motion
        local time = 0
        local originalY = petModel.PrimaryPart.Position.Y
        local bounceConnection
        bounceConnection = RunService.Heartbeat:Connect(function(dt)
            if petModel and petModel.PrimaryPart then
                time = time + dt
                local offset = math.abs(math.sin(time * speed * 5)) * 2
                petModel:SetPrimaryPartCFrame(CFrame.new(
                    petModel.PrimaryPart.Position.X,
                    originalY + offset,
                    petModel.PrimaryPart.Position.Z
                ) * CFrame.Angles(math.sin(time * 3) * 0.1, time * 2, 0))
            else
                bounceConnection:Disconnect()
            end
        end)
        return bounceConnection
        
    elseif animData.type == "tumble" then
        -- Tumbling end over end
        local time = 0
        local tumbleConnection
        tumbleConnection = RunService.Heartbeat:Connect(function(dt)
            if petModel and petModel.PrimaryPart then
                time = time + dt
                petModel:SetPrimaryPartCFrame(petModel.PrimaryPart.CFrame * CFrame.Angles(dt * speed * 6, dt * speed * 3, 0))
            else
                tumbleConnection:Disconnect()
            end
        end)
        return tumbleConnection
        
    elseif animData.type == "float" then
        -- Gentle floating
        local time = 0
        local floatConnection
        floatConnection = RunService.Heartbeat:Connect(function(dt)
            if petModel and petModel.PrimaryPart then
                time = time + dt
                local yOffset = math.sin(time * 2) * 0.5
                local rotation = math.sin(time * 0.5) * 0.2
                petModel:SetPrimaryPartCFrame(petModel.PrimaryPart.CFrame * CFrame.Angles(rotation, 0, 0) + Vector3.new(0, yOffset, 0))
            else
                floatConnection:Disconnect()
            end
        end)
        return floatConnection
        
    elseif animData.type == "wave" then
        -- Waving motion
        local time = 0
        local waveConnection
        waveConnection = RunService.Heartbeat:Connect(function(dt)
            if petModel and petModel.PrimaryPart then
                time = time + dt
                local wave = math.sin(time * speed * 4) * 0.3
                petModel:SetPrimaryPartCFrame(petModel.PrimaryPart.CFrame * CFrame.Angles(0, wave, wave))
            else
                waveConnection:Disconnect()
            end
        end)
        return waveConnection
        
    elseif animData.type == "sleep" then
        -- Sleeping (curled up, slow rotation)
        -- Scale down slightly to look curled
        petModel:ScaleTo(0.8 * (_G.PetSize or 1))
        local sleepConnection
        sleepConnection = RunService.Heartbeat:Connect(function(dt)
            if petModel and petModel.PrimaryPart then
                petModel:SetPrimaryPartCFrame(petModel.PrimaryPart.CFrame * CFrame.Angles(0, dt * 0.5, 0))
            else
                sleepConnection:Disconnect()
            end
        end)
        return sleepConnection
    end
end

