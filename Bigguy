local function addShapeOutlineToPet(petModel, petType)
    if not petModel then return end
    if not outlinesEnabled or not AntiLag.EnableOutlines then return end
    
    local outlineColor = OutlineConfig.Colors[petType] or OutlineConfig.Colors.fr
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "PetShapeOutline"
    highlight.Adornee = petModel
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
