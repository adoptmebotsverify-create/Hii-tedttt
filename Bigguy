-- ==============================================
-- FADE OUT AND DESTROY PET FUNCTION
-- ==============================================

local function fadeOutAndDestroyPet(petModel)
    if not petModel or not petModel.Parent then return end
    if petModel:GetAttribute("IsFading") then return end
    
    petModel:SetAttribute("IsFading", true)
    
    -- Disable touch events while fading
    for _, part in pairs(petModel:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanTouch = false
        end
    end
    
    -- Create fade out tween for all parts
    for _, part in pairs(petModel:GetDescendants()) do
        if part:IsA("BasePart") then
            local tween = TweenService:Create(part, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {
                Transparency = 1
            })
            tween:Play()
        end
    end
    
    -- Fade out highlights/outlines
    for _, child in pairs(petModel:GetDescendants()) do
        if child:IsA("Highlight") then
            local tween = TweenService:Create(child, TweenInfo.new(0.5), {
                OutlineTransparency = 1,
                FillTransparency = 1
            })
            tween:Play()
        end
        if child:IsA("Trail") then
            local tween = TweenService:Create(child, TweenInfo.new(0.5), {
                Transparency = NumberSequence.new(1)
            })
            tween:Play()
        end
        if child:IsA("PointLight") then
            local tween = TweenService:Create(child, TweenInfo.new(0.5), {
                Brightness = 0
            })
            tween:Play()
        end
    end
    
    -- Destroy after fade
    task.wait(0.6)
    
    for id, pet in pairs(activePets) do
        if pet == petModel then
            activePets[id] = nil
            break
        end
    end
    
    petModel:Destroy()
end

-- ==============================================
-- OPTIMIZED RAIN PET FUNCTION
-- ==============================================

local activePets = {}
local isRaining = false
local isContinuous = false
local continuousConnection = nil
local petIdCounter = 0
local totalSpawned = 0
local spawnRate = 0
local speedValue = 5

local function createRainPet()
    if #AllPets == 0 then return nil end
    
    local currentPetCount = 0
    for _,_ in pairs(activePets) do
        currentPetCount = currentPetCount + 1
    end
    
    if currentPetCount >= AntiLag.MaxPetsAtOnce then
        return nil
    end
    
    local petData = AllPets[math.random(1, #AllPets)]
    
    local properties = {
        pet_trick_level = 5,
        age = math.random(1, 6),
        ailments_completed = 0,
        rp_name = GenerateUniquePetName(),
        flyable = true,
        rideable = true,
        mega_neon = (selectedType == "mfr"),
        neon = (selectedType == "nfr")
    }
    
    if selectedType == "mfr" then
        properties.friendship_level = math.random(1, 5)
    end
    
    local item = CreateInventoryItem(petData.id, "pets", properties)
    
    local model = FetchPetModel(petData.kind)
    
    if not model then
        model = Instance.new("Model")
        model.Name = petData.name
        
        local part = Instance.new("Part")
        part.Size = Vector3.new(1.5, 1.5, 1.5)
        part.Anchored = false
        part.CanCollide = false
        
        if selectedType == "mfr" then
            part.BrickColor = BrickColor.new("Really red")
        elseif selectedType == "nfr" then
            part.BrickColor = BrickColor.new("Bright green")
        else
            part.BrickColor = BrickColor.new("Bright blue")
        end
        
        part.Parent = model
        model.PrimaryPart = part
    else
        model:ScaleTo(1.2)
    end
    
    if model.PrimaryPart then
        if AntiLag.EnableTrails then
            local trail = Instance.new("Trail")
            trail.Attachment0 = Instance.new("Attachment", model.PrimaryPart)
            trail.Attachment1 = Instance.new("Attachment", model.PrimaryPart)
            trail.Attachment1.Position = Vector3.new(0, -1, 0)
            
            if selectedType == "mfr" then
                trail.Color = ColorSequence.new(Color3.fromRGB(255, 0, 255))
            elseif selectedType == "nfr" then
                trail.Color = ColorSequence.new(Color3.fromRGB(0, 255, 0))
            else
                trail.Color = ColorSequence.new(Color3.fromRGB(0, 150, 255))
            end
            
            trail.Transparency = NumberSequence.new(0.3)
            trail.Lifetime = 0.4
            trail.Parent = model.PrimaryPart
        end
        
        if AntiLag.EnableLights then
            local light = Instance.new("PointLight")
            light.Range = 6
            light.Brightness = 0.8
            
            if selectedType == "mfr" then
                light.Color = Color3.fromRGB(255, 0, 255)
            elseif selectedType == "nfr" then
                light.Color = Color3.fromRGB(0, 255, 0)
            else
                light.Color = Color3.fromRGB(0, 150, 255)
            end
            
            light.Parent = model.PrimaryPart
        end
        
        if outlinesEnabled and AntiLag.EnableOutlines then
            addShapeOutlineToPet(model, selectedType)
        end
    end
    
    -- Get player position for close spawn
    local character = LocalPlayer.Character
    local spawnPos
    
    if character and character:FindFirstChild("HumanoidRootPart") then
        local rootPart = character.HumanoidRootPart
        local playerPos = rootPart.Position
        
        local angle = math.random() * 2 * math.pi
        local distance = math.random(10, 20)
        local xOffset = math.cos(angle) * distance
        local zOffset = math.sin(angle) * distance
        
        spawnPos = Vector3.new(
            playerPos.X + xOffset,
            playerPos.Y + 25,
            playerPos.Z + zOffset
        )
    else
        local camera = workspace.CurrentCamera
        local viewportSize = camera.ViewportSize
        local randomX = math.random(100, viewportSize.X - 100)
        local ray = camera:ViewportPointToRay(randomX, -50)
        spawnPos = ray.Origin + ray.Direction * 50
    end
    
    model.Parent = workspace
    if model.PrimaryPart then
        model:SetPrimaryPartCFrame(CFrame.new(spawnPos) * CFrame.Angles(0, math.random(0, 360), 0))
    end
    
    -- Minimal spin animation while falling
    local spinConnection
    local lastUpdate = tick()
    spinConnection = RunService.Heartbeat:Connect(function()
        if model and model.PrimaryPart and model.Parent and not model:GetAttribute("HasLanded") then
            local currentTime = tick()
            if currentTime - lastUpdate > 0.05 then
                model:SetPrimaryPartCFrame(model.PrimaryPart.CFrame * CFrame.Angles(0, 0.15, 0))
                lastUpdate = currentTime
            end
        elseif not model or not model.Parent then
            if spinConnection then spinConnection:Disconnect() end
        end
    end)
    
    -- Falling tween
    local targetPos = Vector3.new(
        spawnPos.X,
        spawnPos.Y - 20,
        spawnPos.Z
    )
    
    local fallTime = 1.5 / (speedValue / 5)
    
    local tween = TweenService:Create(model, TweenInfo.new(fallTime, Enum.EasingStyle.Quad), {
        CFrame = CFrame.new(targetPos)
    })
    
    tween:Play()
    
    model:SetAttribute("CreationTime", tick())
    model:SetAttribute("IsFading", false)
    model:SetAttribute("HasLanded", false)
    
    -- When pet lands, mark as landed
    tween.Completed:Connect(function()
        if spinConnection then spinConnection:Disconnect() end
        if model and model.Parent and not model:GetAttribute("IsFading") then
            model:SetAttribute("HasLanded", true)
            
            -- Anchor the pet so it doesn't move
            for _, part in pairs(model:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Anchored = true
                end
            end
        end
    end)
    
    petIdCounter = petIdCounter + 1
    local petId = "pet_" .. petIdCounter
    activePets[petId] = model
    totalSpawned = totalSpawned + 1
    
    Debris:AddItem(model, AntiLag.PetLifetime)
    
    return model
end

-- ==============================================
-- BATCH SPAWN FUNCTION
-- ==============================================

local function spawnBatch(batchSize)
    local spawned = 0
    for i = 1, batchSize do
        updateFPS()
        
        local success = pcall(createRainPet)
        if success then
            spawned = spawned + 1
        end
        
        if i < batchSize then
            task.wait(AntiLag.SpawnDelay)
        end
    end
    return spawned
end

-- ==============================================
-- CONTINUOUS RAIN FUNCTION
-- ==============================================

local function startContinuousRain()
    if isContinuous then
        -- Stop continuous rain
        isContinuous = false
        if continuousConnection then
            continuousConnection:Disconnect()
            continuousConnection = nil
        end
        continuousStatus.Text = "⏸ Continuous mode: OFF"
        continuousStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        rainButton.Text = "☔ START RAIN ☔"
        statusLabel.Text = "Continuous rain stopped"
        return
    end
    
    isContinuous = true
    continuousStatus.Text = "▶ Continuous mode: ON (100/5s)"
    continuousStatus.TextColor3 = Color3.fromRGB(100, 255, 100)
    rainButton.Text = "☔ STOP RAIN ☔"
    statusLabel.Text = "Continuous rain active - 100 pets/5s"
    
    totalSpawned = 0
    
    continuousConnection = RunService.Heartbeat:Connect(function() end)
    
    spawn(function()
        while isContinuous and screenGui and screenGui.Parent do
            local startTime = tick()
            local spawned = 0
            local batches = 5
            
            statusLabel.Text = "Raining batch 1/5..."
            
            for batch = 1, batches do
                if not isContinuous then break end
                
                statusLabel.Text = "Raining batch " .. batch .. "/5..."
                local batchSpawned = spawnBatch(AntiLag.BatchSize)
                spawned = spawned + batchSpawned
                
                if batch < batches and isContinuous then
                    task.wait(AntiLag.BatchDelay)
                end
            end
            
            local elapsed = tick() - startTime
            spawnRate = math.floor(spawned / elapsed)
            
            local waitTime = 5 - elapsed
            if waitTime > 0 and isContinuous then
                task.wait(waitTime)
            end
        end
        
        isContinuous = false
        continuousStatus.Text = "⏸ Continuous mode: OFF"
        continuousStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        rainButton.Text = "☔ START RAIN ☔"
        statusLabel.Text = "Continuous rain stopped"
    end)
end

