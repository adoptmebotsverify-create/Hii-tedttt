    highlight.Parent = petModel
    
    return highlight
end

-- ==============================================
-- DELETE CLOSEST PET FUNCTION
-- ==============================================

local function deleteClosestPet()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        statusLabel.Text = "No character found!"
        task.wait(1)
        statusLabel.Text = "Ready"
        return
    end
    
    local playerPos = character.HumanoidRootPart.Position
    local closestPet = nil
    local closestDistance = math.huge
    local closestPetName = "Unknown"
    
    -- Find the closest landed pet that's not fading
    for _, pet in pairs(activePets) do
        if pet and pet.Parent and pet:GetAttribute("HasLanded") and not pet:GetAttribute("IsFading") then
            -- Get pet position (using primary part or first part)
            local petPos
            if pet.PrimaryPart then
                petPos = pet.PrimaryPart.Position
            else
                -- Find any part to get position
                for _, part in pairs(pet:GetDescendants()) do
                    if part:IsA("BasePart") then
                        petPos = part.Position
                        break
                    end
                end
            end
            
            if petPos then
                local distance = (playerPos - petPos).Magnitude
                if distance < closestDistance then
                    closestDistance = distance
                    closestPet = pet
                    closestPetName = pet.Name or "Pet"
                end
            end
        end
    end
    
    if not closestPet then
        statusLabel.Text = "No landed pets found!"
        task.wait(1)
        statusLabel.Text = "Ready"
        return
    end
    
    -- Show dialog confirmation
    showDialog(
        "Confirm Deletion",
        "Are you sure you want to delete this pet?",
        closestPetName,
        closestPet,
        nil
    )
end

-- Connect delete button
deleteButton.MouseButton1Click:Connect(deleteClosestPet)

