    cleanupAllPrompts()
    screenGui:Destroy()
    for id, pet in pairs(activePets) do
        if pet and pet.Parent then
            pcall(function() pet:Destroy() end)
        end
    end
    RedeemablePets = {}
end)

rainButton.MouseButton1Click:Connect(function()
    if not isRaining then
