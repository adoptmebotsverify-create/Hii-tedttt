-- ==============================================
-- CLEAN UP PROMPTS ON CLOSE
-- ==============================================

local function cleanupAllPrompts()
    for id, data in pairs(activePrompts) do
        if data.prompt then
            pcall(function() data.prompt:Destroy() end)
        end
        if data.part then
            pcall(function() data.part:Destroy() end)
        end
    end
    activePrompts = {}
end

