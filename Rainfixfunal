-- CREATE INVENTORY ITEM
-- ==============================================

local NextToyOrder = 60000
local SpawnedItems = {}
local RedeemablePets = {} -- Track pets that can be redeemed

local function CreateInventoryItem(itemId, category, properties)
    local uniqueId = GenerateUniqueID()
    local itemKindData = KindDB[itemId]

    if not itemKindData then
        warn("Item not found: " .. itemId)
        return nil
    end

    properties = properties or {}
    local newnessValue = NextToyOrder

    if category == "pets" then
        local groupKey = GetPropertyGroup(properties)
        NewnessGroups[groupKey] = NewnessGroups[groupKey] - 1
        newnessValue = NewnessGroups[groupKey]

        if not properties.ailments_completed then
            properties.ailments_completed = 0
        end

        if not properties.rp_name or properties.rp_name == "" then
            properties.rp_name = GenerateUniquePetName()
        end
        
        if properties.mega_neon and not properties.friendship_level then
            properties.friendship_level = math.random(1, 5)
        end
    else
        NextToyOrder = NextToyOrder - 1
        newnessValue = NextToyOrder
    end

    local itemData = {
        unique = uniqueId,
        category = category,
        id = itemId,
        kind = itemKindData.kind,
        newness_order = newnessValue,
        properties = properties,
        _source = "rain_pet",
        isRedeemable = true -- Mark as redeemable
    }

    if category == "pets" then
        SpawnedPets[uniqueId] = { data = itemData, model = nil }
    end
    
    SpawnedItems[uniqueId] = true

    return itemData
end

-- ==============================================
-- FIXED REDEEM PET FUNCTION
-- ==============================================

local function RedeemPet(petData, petModel)
    if not petData or not petModel then return false end
    
    -- Log for debugging
    print("Attempting to redeem pet: " .. (petData.properties.rp_name or "Unknown"))
    
    -- Add to inventory
    local success, result = pcall(function()
        local identity = get_thread_identity and get_thread_identity() or 8
        set_thread_identity(2)
        local inventory = ClientData.get("inventory")
        if inventory and inventory.pets then
            inventory.pets[petData.unique] = petData
            print("✅ Pet redeemed: " .. (petData.properties.rp_name or "Unknown"))
        else
            warn("Inventory not found!")
        end
        set_thread_identity(identity)
    end)
    
    if not success then
        warn("Failed to add pet to inventory")
        return false
    end
    
    -- Remove the physical pet with fade effect
    if petModel and petModel.Parent then
        -- Fade out effect
        for _, part in pairs(petModel:GetDescendants()) do
            if part:IsA("BasePart") then
                TweenService:Create(part, TweenInfo.new(0.5), {Transparency = 1}):Play()
            end
        end
        
        -- Remove proximity prompt if exists
        for id, promptData in pairs(activePrompts) do
            if promptData.petData.unique == petData.unique then
                if promptData.prompt then
                    pcall(function() promptData.prompt:Destroy() end)
                end
                if promptData.part then
                    pcall(function() promptData.part:Destroy() end)
                end
                activePrompts[id] = nil
                break
            end
        end
        
        task.wait(0.5)
        pcall(function() petModel:Destroy() end)
    end
    
    -- Remove from redeemable pets table
    for i = #RedeemablePets, 1, -1 do
        if RedeemablePets[i] and RedeemablePets[i].petData and RedeemablePets[i].petData.unique == petData.unique then
            table.remove(RedeemablePets, i)
            break
        end
    end
    
    -- Remove from spawned pets table
    SpawnedPets[petData.unique] = nil
    
    -- Refresh backpack
    task.defer(function()
        pcall(function()
            if UIManager and UIManager.apps and UIManager.apps.BackpackApp then
                UIManager.apps.BackpackApp:refresh_rendered_items()
            end
        end)
    end)
    
    return true
end

-- ==============================================
-- FIXED KEEP ALL PETS FUNCTION
-- ==============================================

local function keepAllPets()
    local count = #RedeemablePets
    if count == 0 then
        statusLabel.Text = "No pets to keep!"
        task.wait(1)
        statusLabel.Text = "Ready"
        return
    end
    
    statusLabel.Text = "Keeping " .. count .. " pets..."
    keepAllButton.Text = "KEEPING..."
    keepAllButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    keepAllButton.Active = false
    
    local kept = 0
    local failed = 0
    
    -- Make a copy of the table to avoid modification during iteration
    local petsToKeep = {}
    for i, redeemable in ipairs(RedeemablePets) do
        table.insert(petsToKeep, {
            petData = redeemable.petData,
            petModel = redeemable.petModel
        })
    end
    
    print("Found " .. #petsToKeep .. " pets to keep")
    
    -- Redeem each pet
    for i, redeemable in ipairs(petsToKeep) do
        local success = pcall(function()
            local result = RedeemPet(redeemable.petData, redeemable.petModel)
            if result then
                kept = kept + 1
            else
                failed = failed + 1
            end
        end)
        
        if not success then
            failed = failed + 1
            warn("Failed to keep pet #" .. i)
        end
        
        statusLabel.Text = "Keeping " .. kept .. "/" .. count .. " pets..."
        task.wait(0.1) -- Small delay between redemptions
    end
    
    if failed > 0 then
        statusLabel.Text = "Kept " .. kept .. "/" .. count .. " pets (" .. failed .. " failed)"
    else
        statusLabel.Text = "Kept " .. kept .. " pets!"
    end
    
    keepAllButton.Text = "💾 KEEP ALL PETS 💾"
    keepAllButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
    keepAllButton.Active = true
    
    task.wait(2)
    statusLabel.Text = "Ready"
end

-- ==============================================
-- PROXIMITY PROMPT SYSTEM
-- ==============================================

-- Track active prompts
local activePrompts = {}

-- Create a proximity prompt for a pet
local function createProximityPrompt(petModel, petData)
    if not petModel or not petData then return end
    
    -- Create a part for the prompt to attach to
    local promptPart = Instance.new("Part")
    promptPart.Size = Vector3.new(4, 4, 4)
    promptPart.Transparency = 1
    promptPart.Anchored = true
    promptPart.CanCollide = false
    promptPart.Parent = petModel
    
    -- Position it near the pet
    if petModel.PrimaryPart then
        promptPart.CFrame = petModel.PrimaryPart.CFrame * CFrame.new(0, 2, 0)
    end
    
    -- Create the proximity prompt
    local prompt = Instance.new("ProximityPrompt")
    prompt.Name = "RedeemPet_" .. petData.unique
    prompt.ObjectText = "Redeem Pet"
    prompt.ActionText = "Press E to redeem"
    prompt.HoldDuration = 0
    prompt.Enabled = true
    prompt.MaxActivationDistance = 15
    prompt.Parent = promptPart
    
    -- Store in active prompts
    activePrompts[petData.unique] = {
        prompt = prompt,
        part = promptPart,
        petData = petData,
        petModel = petModel
    }
    
    -- Connect to trigger event
    prompt.Triggered:Connect(function(player)
        if player == LocalPlayer then
            -- Redeem the pet
            local success = RedeemPet(petData, petModel)
            if success then
                -- Clean up prompt
                if activePrompts[petData.unique] then
                    pcall(function() 
                        activePrompts[petData.unique].prompt:Destroy()
                        activePrompts[petData.unique].part:Destroy()
                    end)
                    activePrompts[petData.unique] = nil
                end
            end
        end
    end)
    
    return prompt
end

