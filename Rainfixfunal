-- ==============================================
-- SLIDER DRAGGING
-- ==============================================

local draggingSlider = nil
local petCount = 10
local speedValue = 5

countButton.MouseButton1Down:Connect(function()
    draggingSlider = countSlider
end)

speedButton.MouseButton1Down:Connect(function()
    draggingSlider = speedSlider
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
        local pos = input.Position.X
        local absPos = draggingSlider.AbsolutePosition.X
        local size = draggingSlider.AbsoluteSize.X
        local percent = math.clamp((pos - absPos) / size, 0, 1)
        
        if draggingSlider == countSlider then
            countFill.Size = UDim2.new(percent, 0, 1, 0)
            countButton.Position = UDim2.new(percent, -8, 0.5, -8)
            petCount = math.floor(1 + percent * 49)
            countLabel.Text = "Number of Pets: " .. petCount
        elseif draggingSlider == speedSlider then
            speedFill.Size = UDim2.new(percent, 0, 1, 0)
            speedButton.Position = UDim2.new(percent, -8, 0.5, -8)
            speedValue = 1 + percent * 9
            speedValue = math.floor(speedValue * 10) / 10
            speedLabel.Text = "Speed: " .. speedValue
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = nil
    end
end)

-- ==============================================
-- RAIN PET FUNCTION - WITH REDEEMABLE TRACKING
-- ==============================================

local activePets = {}
local isRaining = false

local function createRainPet()
    if #AllPets == 0 then return nil end
    
    local petData = AllPets[math.random(1, #AllPets)]
    
    -- Create properties based on selected type
    local properties = {
        pet_trick_level = 5,
        age = math.random(1, 6),
        ailments_completed = 0,
        rp_name = GenerateUniquePetName(),
        flyable = true,
        rideable = true,
        mega_neon = (selectedType == "mfr"),
        neon = (selectedType == "nfr")
    }
    
    if selectedType == "mfr" then
        properties.friendship_level = math.random(1, 5)
    end
    
    -- Create inventory item (not added to inventory yet)
    local item = CreateInventoryItem(petData.id, "pets", properties)
    if not item then return nil end
    
    -- Load pet model
    local model = FetchPetModel(petData.kind)
    
    if not model then
        -- Fallback model
        model = Instance.new("Model")
        model.Name = petData.name
        
        local part = Instance.new("Part")
        part.Size = Vector3.new(2, 2, 2)
        part.Anchored = false
        part.CanCollide = false
        
        -- Color based on type
        if selectedType == "mfr" then
            part.BrickColor = BrickColor.new("Really red")
            part.Material = Enum.Material.Neon
        elseif selectedType == "nfr" then
            part.BrickColor = BrickColor.new("Bright green")
            part.Material = Enum.Material.Neon
        else -- fr
            part.BrickColor = BrickColor.new("Bright blue")
        end
        
        local mesh = Instance.new("SpecialMesh")
        mesh.MeshType = Enum.MeshType.Sphere
        mesh.Parent = part
        
        part.Parent = model
        model.PrimaryPart = part
    else
        model:ScaleTo(1.5)
    end
    
    -- Add trail
    if model.PrimaryPart then
        local trail = Instance.new("Trail")
        trail.Attachment0 = Instance.new("Attachment", model.PrimaryPart)
        trail.Attachment1 = Instance.new("Attachment", model.PrimaryPart)
        trail.Attachment1.Position = Vector3.new(0, -2, 0)
        
        if selectedType == "mfr" then
            trail.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 255)),
                ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 0))
            })
        elseif selectedType == "nfr" then
            trail.Color = ColorSequence.new(Color3.fromRGB(0, 255, 0))
        else
            trail.Color = ColorSequence.new(Color3.fromRGB(0, 150, 255))
        end
        
        trail.Transparency = NumberSequence.new(0.3)
        trail.Lifetime = 0.8
        trail.Parent = model.PrimaryPart
        
        -- Add light
        local light = Instance.new("PointLight")
        light.Range = 10
        light.Brightness = 1.5
        
        if selectedType == "mfr" then
            light.Color = Color3.fromRGB(255, 0, 255)
        elseif selectedType == "nfr" then
            light.Color = Color3.fromRGB(0, 255, 0)
        else
            light.Color = Color3.fromRGB(0, 150, 255)
        end
        
        light.Parent = model.PrimaryPart
    end
    
    -- Position at top of screen
    local camera = workspace.CurrentCamera
    local viewportSize = camera.ViewportSize
    local randomX = math.random(100, viewportSize.X - 100)
    local ray = camera:ViewportPointToRay(randomX, -50)
    local spawnPos = ray.Origin + ray.Direction * 150
    
    model.Parent = workspace
    if model.PrimaryPart then
        model:SetPrimaryPartCFrame(CFrame.new(spawnPos) * CFrame.Angles(0, math.random(0, 360), 0))
    end
    
    -- Simple spin animation
    local spinConnection
    spinConnection = RunService.Heartbeat:Connect(function(dt)
        if model and model.PrimaryPart and model.Parent then
            model:SetPrimaryPartCFrame(model.PrimaryPart.CFrame * CFrame.Angles(0, dt * speedValue * 2, 0))
        else
            if spinConnection then spinConnection:Disconnect() end
        end
    end)
    
    -- Falling tween
    local targetPos = spawnPos - Vector3.new(0, 400, 0)
    local fallTime = 3 / (speedValue / 5)
    
    local tween = TweenService:Create(model, TweenInfo.new(fallTime, Enum.EasingStyle.Quad), {
        CFrame = CFrame.new(targetPos)
    })
    
    tween:Play()
    
    -- When pet lands, make it redeemable
    tween.Completed:Connect(function()
        if spinConnection then spinConnection:Disconnect() end
        
        -- Make pet stationary
        if model and model.PrimaryPart then
            model.PrimaryPart.Anchored = true
        end
        
        -- Add to redeemable pets list
        if model and model.Parent then
            table.insert(RedeemablePets, {
                petData = item,
                petModel = model
            })
            
            -- Create proximity prompt
            createProximityPrompt(model, item)
            
            -- Add highlight
            if model.PrimaryPart then
                local highlight = Instance.new("SelectionBox")
                highlight.Adornee = model.PrimaryPart
                highlight.LineThickness = 0.05
                highlight.Color3 = Color3.fromRGB(255, 255, 0)
                highlight.Transparency = 0.5
                highlight.Parent = model.PrimaryPart
            end
            
            -- Update pet counter
            petCounterLabel.Text = "Pets on ground: " .. #RedeemablePets
            print("Pet landed, total redeemable: " .. #RedeemablePets)
        end
    end)
    
    -- Store in active pets
    local petId = tostring(math.random())
    activePets[petId] = model
    
    Debris:AddItem(model, 120) -- Keep for 2 minutes to allow redemption
    
    return model
end

-- ==============================================
-- RAIN FUNCTION
-- ==============================================

local function startRain()
    if isRaining then 
        statusLabel.Text = "Already raining!"
        return 
    end
    
    isRaining = true
    rainButton.Text = "RAINING..."
    rainButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    rainButton.Active = false
    
    local typeNames = {fr = "FR", nfr = "NFR", mfr = "MFR"}
    statusLabel.Text = "Raining " .. petCount .. " " .. typeNames[selectedType] .. " pets..."
    
    for i = 1, petCount do
        local success = pcall(createRainPet)
        if not success then
            warn("Failed to create pet #" .. i)
        end
        
        if i % 5 == 0 then
            statusLabel.Text = "Spawned " .. i .. "/" .. petCount .. " pets..."
        end
        
        if i < petCount then
            task.wait(0.15)
        end
    end
    
    statusLabel.Text = "Complete! (" .. petCount .. " pets)"
    rainButton.Text = "☔ MAKE IT RAIN ☔"
    rainButton.BackgroundColor3 = Color3.fromRGB(0, 180, 255)
    rainButton.Active = true
    
    task.wait(2)
    statusLabel.Text = "Ready"
    isRaining = false
end

