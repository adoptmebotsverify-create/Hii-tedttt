local activePets = {}
local isRaining = false

local function createRainPet()
    if #AllPets == 0 then return nil end
    
    local petData = AllPets[math.random(1, #AllPets)]
    
    -- Create properties based on selected type
    local properties = {
        pet_trick_level = 5,
        age = math.random(1, 6),
        ailments_completed = 0,
        rp_name = GenerateUniquePetName(),
        flyable = true,
        rideable = true,
        mega_neon = (selectedType == "mfr"),
        neon = (selectedType == "nfr")
    }
    
    if selectedType == "mfr" then
        properties.friendship_level = math.random(1, 5)
    end
    
    -- Create inventory item (adds to inventory)
    local item = CreateInventoryItem(petData.id, "pets", properties)
    
    -- Load pet model
    local model = FetchPetModel(petData.kind)
    
    if not model then
        -- Fallback model
        model = Instance.new("Model")
        model.Name = petData.name
        
        local part = Instance.new("Part")
        part.Size = Vector3.new(2, 2, 2)
        part.Anchored = false
        part.CanCollide = false
        
        -- Color based on type
        if selectedType == "mfr" then
            part.BrickColor = BrickColor.new("Really red")
            part.Material = Enum.Material.Neon
        elseif selectedType == "nfr" then
            part.BrickColor = BrickColor.new("Bright green")
            part.Material = Enum.Material.Neon
        else -- fr
            part.BrickColor = BrickColor.new("Bright blue")
        end
        
        local mesh = Instance.new("SpecialMesh")
        mesh.MeshType = Enum.MeshType.Sphere
        mesh.Parent = part
        
        part.Parent = model
        model.PrimaryPart = part
    else
        model:ScaleTo(1.5)
    end
    
    -- Add trail
    if model.PrimaryPart then
        local trail = Instance.new("Trail")
        trail.Attachment0 = Instance.new("Attachment", model.PrimaryPart)
        trail.Attachment1 = Instance.new("Attachment", model.PrimaryPart)
        trail.Attachment1.Position = Vector3.new(0, -2, 0)
        
        if selectedType == "mfr" then
            trail.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 255)),
                ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 0))
            })
        elseif selectedType == "nfr" then
            trail.Color = ColorSequence.new(Color3.fromRGB(0, 255, 0))
        else
            trail.Color = ColorSequence.new(Color3.fromRGB(0, 150, 255))
        end
        
        trail.Transparency = NumberSequence.new(0.3)
        trail.Lifetime = 0.8
        trail.Parent = model.PrimaryPart
        
        -- Add light
        local light = Instance.new("PointLight")
        light.Range = 10
        light.Brightness = 1.5
        
        if selectedType == "mfr" then
            light.Color = Color3.fromRGB(255, 0, 255)
        elseif selectedType == "nfr" then
            light.Color = Color3.fromRGB(0, 255, 0)
        else
            light.Color = Color3.fromRGB(0, 150, 255)
        end
        
        light.Parent = model.PrimaryPart
    end
    
    -- ===== FIXED: Get player position for close spawn =====
    local character = LocalPlayer.Character
    local spawnPos
    
    if character and character:FindFirstChild("HumanoidRootPart") then
        -- Spawn near player
        local rootPart = character.HumanoidRootPart
        local playerPos = rootPart.Position
        
        -- Random offset within 15-30 studs in a circle around player
        local angle = math.random() * 2 * math.pi
        local distance = math.random(15, 30)
        local xOffset = math.cos(angle) * distance
        local zOffset = math.sin(angle) * distance
        
        -- Spawn at a height above player
        spawnPos = Vector3.new(
            playerPos.X + xOffset,
            playerPos.Y + 40, -- 40 studs above player
            playerPos.Z + zOffset
        )
    else
        -- Fallback to camera-based positioning if character not found
        local camera = workspace.CurrentCamera
        local viewportSize = camera.ViewportSize
        local randomX = math.random(100, viewportSize.X - 100)
        local ray = camera:ViewportPointToRay(randomX, -50)
        spawnPos = ray.Origin + ray.Direction * 50
    end
    
    model.Parent = workspace
    if model.PrimaryPart then
        model:SetPrimaryPartCFrame(CFrame.new(spawnPos) * CFrame.Angles(0, math.random(0, 360), 0))
    end
    
    -- Simple spin animation
    local spinConnection
    spinConnection = RunService.Heartbeat:Connect(function(dt)
        if model and model.PrimaryPart and model.Parent then
            model:SetPrimaryPartCFrame(model.PrimaryPart.CFrame * CFrame.Angles(0, dt * speedValue * 2, 0))
        else
            if spinConnection then spinConnection:Disconnect() end
        end
    end)
    
    -- Falling tween - now falls to ground near player
    local targetPos = Vector3.new(
        spawnPos.X,
        spawnPos.Y - 35, -- Fall 35 studs down
        spawnPos.Z
    )
    
    local fallTime = 2.5 / (speedValue / 5)
    
    local tween = TweenService:Create(model, TweenInfo.new(fallTime, Enum.EasingStyle.Quad), {
        CFrame = CFrame.new(targetPos)
    })
    
    tween:Play()
    
    -- Clean up when done
    tween.Completed:Connect(function()
        if spinConnection then spinConnection:Disconnect() end
        if model and model.Parent then
            -- Fade out
            for _, part in pairs(model:GetDescendants()) do
                if part:IsA("BasePart") then
                    TweenService:Create(part, TweenInfo.new(1), {Transparency = 1}):Play()
                end
            end
            task.wait(1)
            model:Destroy()
        end
    end)
    
    -- Store in active pets
    local petId = tostring(math.random())
    activePets[petId] = model
    
    Debris:AddItem(model, 10)
    
    return model
end

