-- Slider interactions
local function updateSlider(input, slider, fill, label, min, max, callback)
    local pos = input.Position.X
    local absPos = slider.AbsolutePosition.X
    local size = slider.AbsoluteSize.X
    
    local percent = math.clamp((pos - absPos) / size, 0, 1)
    fill.Size = UDim2.new(percent, 0, 1, 0)
    
    local value = math.floor(min + (max - min) * percent)
    label.Text = label.Text:gsub("%d+", tostring(value))
    callback(value)
end

amountSlider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        updateSlider(input, amountSlider, amountFill, amountLabel, 1, 50, function(val)
            amountValue = val
        end)
    end
end)

speedSlider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        updateSlider(input, speedSlider, speedFill, speedLabel, 1, 10, function(val)
            speedValue = val
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        if amountSlider.Active then
            updateSlider(input, amountSlider, amountFill, amountLabel, 1, 50, function(val)
                amountValue = val
            end)
        elseif speedSlider.Active then
            updateSlider(input, speedSlider, speedFill, speedLabel, 1, 10, function(val)
                speedValue = val
            end)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

