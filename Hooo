-- Functions
local function GenerateUniqueID()
    return HttpService:GenerateGUID(false)
end

local function GetRandomPet()
    return AllPets[math.random(1, #AllPets)]
end

local function CreateRainPet()
    local petData = GetRandomPet()
    if not petData then return end
    
    -- Create pet model
    local success, petModel = pcall(function()
        return DownloadClient.promise_download_copy("Pets", petData.id):expect()
    end)
    
    if not success or not petModel then
        warn("Failed to load pet: " .. petData.name)
        return
    end
    
    local model = petModel:Clone()
    
    -- Random position at top of screen
    local viewportSize = workspace.CurrentCamera.ViewportSize
    local randomX = math.random(100, viewportSize.X - 100)
    local ray = workspace.CurrentCamera:ViewportPointToRay(randomX, -50)
    local rainPos = ray.Origin + ray.Direction * 100
    
    -- Add some random offset
    rainPos = rainPos + Vector3.new(math.random(-30, 30), 0, math.random(-30, 30))
    
    model.Parent = workspace
    model:SetPrimaryPartCFrame(CFrame.new(rainPos) * CFrame.Angles(0, math.random(0, 360), 0))
    
    -- Add neon effects if enabled
    if megaNeon and model:FindFirstChild("PetModel") then
        local petModel = model.PetModel
        for _, part in pairs(petModel:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Material = Enum.Material.Neon
                part.Color = Color3.fromHSV(math.random(), 1, 1)
            end
        end
    end
    
    -- Add trail effect
    local trail = Instance.new("Trail")
    trail.Attachment0 = Instance.new("Attachment", model.PrimaryPart)
    trail.Attachment1 = Instance.new("Attachment", model.PrimaryPart)
    trail.Attachment1.Position = Vector3.new(0, -2, 0)
    trail.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255))
    trail.Transparency = NumberSequence.new(0.5)
    trail.Lifetime = 0.5
    trail.Enabled = true
    
    -- Create falling tween
    local targetPos = rainPos - Vector3.new(0, 200, 0)
    local tweenInfo = TweenInfo.new(
        2 / speedValue, -- Speed factor
        Enum.EasingStyle.Quad,
        Enum.EasingDirection.In
    )
    
    local tween = TweenService:Create(model, tweenInfo, {
        CFrame = CFrame.new(targetPos) * CFrame.Angles(math.random(0, 360), math.random(0, 360), math.random(0, 360))
    })
    
    tween:Play()
    
    -- Add spin
    local spinConnection
    spinConnection = RunService.Heartbeat:Connect(function(dt)
        if model and model.PrimaryPart then
            model:SetPrimaryPartCFrame(model.PrimaryPart.CFrame * CFrame.Angles(0, dt * 3, 0))
        else
            spinConnection:Disconnect()
        end
    end)
    
    -- Clean up
    tween.Completed:Connect(function()
        spinConnection:Disconnect()
        -- Fade out and destroy
        if model then
            for _, part in pairs(model:GetDescendants()) do
                if part:IsA("BasePart") then
                    local fadeTween = TweenService:Create(part, TweenInfo.new(1), {Transparency = 1})
                    fadeTween:Play()
                end
            end
            task.wait(1)
            model:Destroy()
        end
    end)
    
    Debris:AddItem(model, 10)
    
    return model
end

local function RainPets()
    local count = amountValue
    counterLabel.Text = "Raining " .. count .. " pets..."
    
    for i = 1, count do
        CreateRainPet()
        if i < count then
            task.wait(0.1) -- Small delay between each pet
        end
    end
    
    counterLabel.Text = "Rain complete!"
    task.wait(1)
    counterLabel.Text = "Ready to rain!"
end

